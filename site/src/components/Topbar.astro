---
import { t, type Locale } from "~/i18n/strings";
import { home, mmIndex, lab, wiki, altPath } from "~/lib/urls";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const s = t(locale);

const navLinks = [
  { href: mmIndex(locale), label: s.nav.mm },
  { href: lab(locale), label: s.nav.lab },
  { href: wiki(locale), label: s.nav.wiki },
];

const zhHref = locale === "zh" ? pathname : altPath(pathname, locale, "zh");
const enHref = locale === "en" ? pathname : altPath(pathname, locale, "en");

const isActive = (href: string) =>
  pathname === href || pathname.startsWith(href + "/");
---

<header class="topbar">
  <a class="topbar__brand" href={home(locale)}>
    <span class="han">{locale === "zh" ? "心 智 七 篇" : "Seven Mental"}</span>
    <span class="latin">· {locale === "zh" ? "Seven Mental Models" : "心智七篇"}</span>
  </a>

  <nav class="topbar__nav" aria-label={s.nav.hall}>
    {
      navLinks.map(({ href, label }, i) => (
        <>
          <a href={href} aria-current={isActive(href) ? "page" : undefined}>
            {label}
          </a>
          {i < navLinks.length - 1 && <span class="dot" aria-hidden="true" />}
        </>
      ))
    }
  </nav>

  <div class="topbar__end">
    <div class="lang-toggle" role="group" aria-label="language">
      <a href={zhHref} aria-current={locale === "zh" ? "page" : undefined}>中</a>
      <a href={enHref} aria-current={locale === "en" ? "page" : undefined}>EN</a>
    </div>

    {/* Search trigger placeholder — uncomment once the Pagefind drawer lands. */}
    {/*
    <button class="icon-btn" type="button" id="search-trigger" aria-label="search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m21 21-4.3-4.3" />
      </svg>
    </button>
    */}

    <button class="icon-btn" type="button" id="theme-toggle" aria-label="toggle theme">
      <svg class="theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
      </svg>
      <svg class="theme-icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
      </svg>
    </button>
  </div>
</header>

<style>
  .theme-icon-light,
  .theme-icon-dark {
    width: 16px;
    height: 16px;
  }
  [data-theme="dark"] .theme-icon-light { display: none !important; }
  [data-theme="dark"] .theme-icon-dark { display: block !important; }
</style>

<script is:inline>
  // Preserve reading position across zh ↔ en language switches.
  //
  // Chapter pages mount `<section class="reader__section" id="s-XX-slug">`
  // where the id is derived from the source markdown filename, so it matches
  // across languages.  On every click of the language toggle we capture:
  //   · the section the reader is currently inside
  //   · how far into that section (as a 0..1 ratio of its height) they've scrolled
  // and stash that in sessionStorage keyed by the destination pathname.  The
  // target page, on load, finds the section with the same id and scrolls to
  // `sectionTop + sectionHeight × ratio`.  Ratios (not pixels) keep the position
  // meaningful even though en sections are ~30-50% longer than zh.
  //
  // Non-chapter pages (home, mm index, wiki lists) don't have sections, so we
  // fall back to a whole-page scrollY ratio.
  //
  // Nothing touches the URL — no `#hash` left behind after the switch.
  (function () {
    "use strict";

    var HEADER_OFFSET = 80;
    var KEY = "lang-switch-scroll:";

    function currentSectionRatio() {
      var sections = document.querySelectorAll("section.reader__section[id]");
      if (!sections.length) return null;
      // Pick the last section whose top has passed the header zone.
      var picked = null;
      for (var i = 0; i < sections.length; i++) {
        var rect = sections[i].getBoundingClientRect();
        if (rect.top <= HEADER_OFFSET) {
          picked = sections[i];
        } else {
          break;
        }
      }
      if (!picked) return null;
      var rect = picked.getBoundingClientRect();
      // How far from the section's top are we in page coordinates?
      // (negative rect.top means we've scrolled past it; offset = -rect.top + HEADER_OFFSET)
      var offsetIntoSection = HEADER_OFFSET - rect.top;
      var height = picked.offsetHeight;
      if (height <= 0) return null;
      var ratio = Math.max(0, Math.min(1, offsetIntoSection / height));
      return { sectionId: picked.id, ratio: ratio };
    }

    function currentPageRatio() {
      var max = document.documentElement.scrollHeight - window.innerHeight;
      if (max <= 0) return 0;
      return Math.max(0, Math.min(1, window.scrollY / max));
    }

    function onLangClick(e) {
      var a = e.currentTarget;
      if (!a || !a.href) return;
      var target;
      try {
        target = new URL(a.href);
      } catch (_) {
        return;
      }
      if (target.pathname === location.pathname) return;

      var payload = null;
      var sec = currentSectionRatio();
      if (sec) {
        payload = { kind: "section", sectionId: sec.sectionId, ratio: sec.ratio };
      } else {
        var r = currentPageRatio();
        if (r > 0.01) payload = { kind: "page", ratio: r };
      }
      if (!payload) return;
      try {
        sessionStorage.setItem(KEY + target.pathname, JSON.stringify(payload));
      } catch (_) {}
    }

    function applyRestore(payload) {
      if (payload.kind === "section") {
        var el = document.getElementById(payload.sectionId);
        if (!el) return false;
        var rect = el.getBoundingClientRect();
        var top = rect.top + window.scrollY;
        var offset = el.offsetHeight * payload.ratio;
        window.scrollTo({ top: top + offset - HEADER_OFFSET, behavior: "instant" });
        return true;
      }
      if (payload.kind === "page") {
        var max = document.documentElement.scrollHeight - window.innerHeight;
        window.scrollTo({ top: max * payload.ratio, behavior: "instant" });
        return true;
      }
      return false;
    }

    function restore() {
      if (location.hash) return; // user-provided anchor wins
      var payload;
      try {
        var key = KEY + location.pathname;
        var raw = sessionStorage.getItem(key);
        if (!raw) return;
        sessionStorage.removeItem(key);
        payload = JSON.parse(raw);
        if (!payload || typeof payload.ratio !== "number") return;
      } catch (_) { return; }

      // Scroll restoration is fragile because the browser + Astro prefetch may
      // reset scroll AFTER our first attempt.  Re-apply over a short window
      // so we win whichever reset happens last.
      var attempts = 0;
      var maxAttempts = 12; // ~600ms at 50ms cadence
      function tick() {
        applyRestore(payload);
        attempts += 1;
        if (attempts < maxAttempts) setTimeout(tick, 50);
      }
      if ("scrollRestoration" in history) {
        try { history.scrollRestoration = "manual"; } catch (_) {}
      }
      requestAnimationFrame(tick);
    }

    function wire() {
      // Fresh DOM on each navigation (ClientRouter swaps the body); re-query
      // the current lang-toggle links and attach capture-phase click handlers.
      var links = document.querySelectorAll(".lang-toggle a[href]");
      for (var i = 0; i < links.length; i++) {
        links[i].addEventListener("click", onLangClick, true);
      }
      restore();
    }

    // Hall.astro mounts <ClientRouter />, so this is an SPA — this inline
    // script only executes on the initial HTML load.  `astro:page-load`
    // fires on every page (initial + after each view transition swap), so
    // we rely on it to re-wire listeners and restore scroll position.
    document.addEventListener("astro:page-load", wire);
    // Fallback: if transitions aren't active yet on the very first page,
    // bootstrap once on DOMContentLoaded too (idempotent re-wiring is fine).
    if (document.readyState !== "loading") {
      wire();
    } else {
      document.addEventListener("DOMContentLoaded", wire, { once: true });
    }
  })();
</script>
