---
/**
 * Singleton modal overlay for CardTriggers.  Mounted once in Hall.astro
 * so any CardTrigger on any page can surface a card through it.
 *
 * Loads `/card-fragment/{lang}/{kind}/{slug}` into an <iframe>.  The
 * iframe gets its own document, which means: Astro scoped styles
 * (`data-astro-cid-*`) are emitted alongside their matching
 * `<style>` in the fragment's own <head> and work without any
 * host-document plumbing.  It also isolates charset + tokens + fonts.
 *
 * The host page's current data-theme is forwarded to the iframe via
 * query string so the card renders in the same day/night mode.
 */
---

<div class="card-modal" role="dialog" aria-modal="true" hidden>
  <button class="card-modal__backdrop" aria-label="close"></button>
  <div class="card-modal__stage">
    <iframe class="card-modal__frame" title="card" hidden></iframe>
    <button class="card-modal__close" type="button" aria-label="close">×</button>
  </div>
</div>

<script>
  (function () {
    const modal = document.querySelector<HTMLElement>(".card-modal");
    if (!modal) return;
    const frame = modal.querySelector<HTMLIFrameElement>(".card-modal__frame")!;
    const backdrop = modal.querySelector<HTMLElement>(".card-modal__backdrop")!;
    const closeBtn = modal.querySelector<HTMLElement>(".card-modal__close")!;

    function open(of: string, lang: string) {
      const theme = document.documentElement.getAttribute("data-theme") ?? "light";
      frame.src = `/card-fragment/${lang}/${of}?theme=${encodeURIComponent(theme)}`;
      frame.hidden = false;
      modal.hidden = false;
      document.body.style.overflow = "hidden";
    }
    function close() {
      modal.hidden = true;
      frame.hidden = true;
      frame.src = "about:blank";
      document.body.style.overflow = "";
    }

    document.addEventListener("click", (e) => {
      const trg = (e.target as HTMLElement).closest<HTMLButtonElement>(".card-trigger");
      if (!trg) return;
      const of = trg.dataset.cardOf!;
      const lang = trg.dataset.cardLang ?? "zh";
      open(of, lang);
    });
    backdrop.addEventListener("click", close);
    closeBtn.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.hidden) close();
    });
    document.addEventListener("astro:before-preparation", close);
  })();
</script>

<style>
  .card-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-modal[hidden] { display: none; }
  .card-modal__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklab, var(--ink) 72%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 0;
    cursor: pointer;
  }
  .card-modal__stage {
    position: relative;
    width: min(560px, 88vw);
    aspect-ratio: 1 / 1.414;
    max-height: calc(100vh - 80px);
    display: flex;
  }
  .card-modal__frame {
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
  }
  .card-modal__close {
    position: absolute;
    top: -40px;
    right: 0;
    width: 32px;
    height: 32px;
    border: 1px solid var(--rule);
    background: var(--paper-raised);
    color: var(--ink);
    font-size: 1.2rem;
    cursor: pointer;
    line-height: 1;
  }
</style>
