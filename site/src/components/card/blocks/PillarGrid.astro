---
interface Props { cols?: 2 | 3 | 4; }
const { cols = 3 } = Astro.props as Props;
---
<div class="pillar-grid" style={`--pg-cols: ${cols};`}>
  <slot />
</div>
<style>
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(var(--pg-cols), minmax(0, 1fr));
    gap: 10px;
    margin: 10px 0;
  }
</style>
