---
interface Props { cite?: string; }
const { cite } = Astro.props as Props;
---
<blockquote class="quote">
  <div class="quote__body"><slot /></div>
  {cite && <footer class="quote__cite">— {cite}</footer>}
</blockquote>
<style>
  .quote {
    margin: 10px 0;
    padding: 8px 0 8px 16px;
    border-left: 2px solid var(--vermilion);
    color: var(--ink-soft);
    font-style: italic;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .quote__cite {
    margin-top: 6px;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
</style>
