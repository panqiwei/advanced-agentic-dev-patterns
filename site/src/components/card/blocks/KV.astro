---
interface Props { label: string; }
const { label } = Astro.props as Props;
---
<div class="kv">
  <dt class="kv__k">{label}</dt>
  <dd class="kv__v"><slot /></dd>
</div>
<style>
  .kv {
    display: grid;
    grid-template-columns: 7em 1fr;
    gap: 14px;
    padding: 6px 0;
    border-bottom: 1px solid var(--rule);
  }
  .kv__k {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding-top: 2px;
  }
  .kv__v {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--ink-soft);
  }
</style>
