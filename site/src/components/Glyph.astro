---
import type { ChapterId } from "~/content/chapters";

interface Props {
  id: ChapterId;
  class?: string;
}

const { id, class: className = "" } = Astro.props;
---

{id === "orthogonality" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    <line x1="8" y1="32" x2="56" y2="32" />
    <line x1="32" y1="8" x2="32" y2="56" />
    <circle cx="32" cy="32" r="18" />
    <circle cx="32" cy="32" r="2" fill="currentColor" />
  </svg>
)}
{id === "cybernetics" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    <path d="M10 32 a22 22 0 1 0 44 0 a22 22 0 1 0 -44 0" />
    <path d="M54 32 l-6 -4 l0 8 Z" fill="currentColor" />
    <circle cx="32" cy="32" r="4" fill="currentColor" />
  </svg>
)}
{id === "entropy" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    {Array.from({ length: 7 }).map((_, i) => (
      <line x1={10 + i * 7} y1={10} x2={10 + i * 7} y2={54} stroke-dasharray={`${2 + i * 2} ${2 + i}`} opacity={1 - i * 0.08} />
    ))}
  </svg>
)}
{id === "operating-system" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    <rect x="8" y="8" width="48" height="48" />
    <line x1="8" y1="22" x2="56" y2="22" />
    <line x1="22" y1="8" x2="22" y2="56" />
    <line x1="40" y1="8" x2="40" y2="56" />
    <line x1="8" y1="40" x2="56" y2="40" />
  </svg>
)}
{id === "fractal" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    <rect x="6" y="6" width="52" height="52" />
    <rect x="20" y="20" width="24" height="24" />
    <rect x="27" y="27" width="10" height="10" />
    <rect x="30" y="30" width="4" height="4" />
  </svg>
)}
{id === "causality" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    <circle cx="14" cy="18" r="3" fill="currentColor" />
    <circle cx="50" cy="18" r="3" fill="currentColor" />
    <circle cx="32" cy="46" r="3" fill="currentColor" />
    <path d="M14 18 L30 44" />
    <path d="M50 18 L34 44" />
    <path d="M14 18 Q32 8 50 18" stroke-dasharray="2 3" />
  </svg>
)}
{id === "symbols-connectionism" && (
  <svg class={className} viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
    <rect x="8" y="12" width="18" height="18" />
    <circle cx="47" cy="21" r="4" fill="currentColor" />
    <circle cx="40" cy="40" r="3" fill="currentColor" />
    <circle cx="54" cy="44" r="3" fill="currentColor" />
    <line x1="47" y1="25" x2="40" y2="37" />
    <line x1="47" y1="25" x2="54" y2="41" />
    <line x1="26" y1="21" x2="43" y2="21" stroke-dasharray="2 3" />
  </svg>
)}
