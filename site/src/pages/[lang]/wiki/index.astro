---
import Hall from "~/layouts/Hall.astro";
import WikiAtlas from "~/components/WikiAtlas.astro";
import { t, type Locale } from "~/i18n/strings";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "zh" } }];
}

const { lang } = Astro.params as { lang: Locale };
const s = t(lang);
---

<Hall
  locale={lang}
  title={`Knowledge Atlas · ${s.siteTitle}`}
  description={lang === "zh" ? "一个活的知识图谱：概念、实体、源头" : "A living knowledge graph — concepts, entities, sources"}
>
  <WikiAtlas locale={lang} />
</Hall>
