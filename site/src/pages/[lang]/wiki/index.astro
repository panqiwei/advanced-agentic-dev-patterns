---
import Hall from "~/layouts/Hall.astro";
import ComingSoon from "~/components/ComingSoon.astro";
import { t, type Locale } from "~/i18n/strings";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "zh" } }];
}

const { lang } = Astro.params as { lang: Locale };
const s = t(lang);
---

<Hall
  locale={lang}
  title={`${s.nav.wiki} · ${s.siteTitle}`}
  description={lang === "zh" ? "索引墙 —— 源头、概念、实体" : "Index shelf — sources, concepts, entities"}
  noIndex
>
  <ComingSoon
    locale={lang}
    kicker={lang === "zh" ? "墙 · INDEX" : "Shelf · INDEX"}
    title={lang === "zh" ? "索引墙" : "Index Shelf"}
    subtitle={
      lang === "zh"
        ? "Sources / Concepts / Entities —— 跨源的知识交叉"
        : "Sources / Concepts / Entities — cross-source knowledge graph"
    }
  />
</Hall>
