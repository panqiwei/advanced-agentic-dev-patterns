---
/**
 * Full HTML document whose body contains ONE card.  Loaded into an
 * <iframe> by CardModal for the trigger-modal flow (so Astro scoped
 * styles work without host-page plumbing), and directly browseable
 * for dev debugging.
 *
 * `?theme=dark|light` query param controls palette; falls back to
 * the static `data-theme` below (dark) if not provided.  CardModal
 * always forwards the host page's current theme.
 */
import { getCollection } from "astro:content";
import OneShotCard from "~/components/card/OneShotCard.astro";
import "~/styles/tokens.css";

export async function getStaticPaths() {
  const all = await getCollection("cards");
  return all.map((entry) => {
    const [lang, kind, slug] = entry.id.split("/");
    return { params: { lang, kind, slug } };
  });
}

const { lang, kind, slug } = Astro.params as { lang: "en" | "zh"; kind: string; slug: string };
const themeParam = Astro.url.searchParams.get("theme");
const theme = themeParam === "dark" || themeParam === "light" ? themeParam : "dark";
---

<!doctype html>
<html lang={lang} data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Card · {kind}/{slug}</title>
  </head>
  <body>
    <div class="card-fragment-root">
      <OneShotCard of={`${kind}/${slug}`} variant="full" lang={lang} />
    </div>
  </body>
</html>

<style is:global>
  html, body { height: 100%; }
  body {
    margin: 0;
    background: transparent;
    display: flex;
  }
  .card-fragment-root {
    width: 100%;
    height: 100%;
    display: flex;
  }
  /* When loaded in an iframe, let the card fill the iframe exactly
     rather than capping at its own width/height tokens. */
  .card-fragment-root > .oscard--full {
    width: 100%;
    max-height: 100%;
    max-width: none;
  }
</style>
